# Copy this file to .env and fill in real values before running
# docker-compose or starting SocketWeb against a local MySQL database.
#
# .env is already covered by .gitignore - never commit the real file,
# only this .example template with placeholder values.

# --- MySQL (read by docker-compose.yml) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=webdesktopsocket
MYSQL_USER=webdesktopsocket_app
MYSQL_PASSWORD=CHANGE_ME
MYSQL_PORT=3306

# --- SocketWeb connection string ---
# ASP.NET Core configuration maps a double-underscore env var name to a
# colon-separated config key, so this maps to ConnectionStrings:ChatDb,
# overriding the local-dev placeholder in SocketWeb/appsettings.json.
# Keep the credentials here in sync with the MYSQL_* values above when
# using docker-compose. Export it in your shell (or use `dotnet
# user-secrets`) before running `dotnet run --project SocketWeb`:
#
#   export ConnectionStrings__ChatDb="Server=127.0.0.1;Port=3306;Database=webdesktopsocket;User=webdesktopsocket_app;Password=CHANGE_ME;"
#
ConnectionStrings__ChatDb=Server=127.0.0.1;Port=3306;Database=webdesktopsocket;User=webdesktopsocket_app;Password=CHANGE_ME;
