<Window x:Class="SocketDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SocketDesktop - AI Bridge" Height="680" Width="440"
        Background="#F0F2F5"
        Loaded="Window_Loaded">

    <!-- The chat UI lives entirely on the web now (see SocketWeb). This
         window is just an operational dashboard for the desktop AI
         bridge: connection/registration state, AI configuration status
         (never the key itself), what request (if any) is being
         processed right now, and a short activity log. -->

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#007AFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0064D1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RowValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Reused for every "colored dot + label" status pill on this page. -->
        <Style x:Key="StatusPillBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="4,0,4,16">
            <TextBlock Text="SocketDesktop" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="AI bridge between SocketWeb and the AI API" FontSize="13" Foreground="#6B7280" Margin="0,2,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Connection -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CONNECTION" Style="{StaticResource CardTitle}" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="WebSocket" Style="{StaticResource RowLabel}" />
                            <Border Grid.Column="1" Style="{StaticResource StatusPillBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="WsStatusDot" Width="8" Height="8" Fill="#FF3B30" VerticalAlignment="Center" />
                                    <TextBlock x:Name="WsStatusText" Text="Disconnected" FontSize="12" FontWeight="SemiBold" Foreground="#B3261E" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Registration" Style="{StaticResource RowLabel}" />
                            <Border Grid.Column="1" Style="{StaticResource StatusPillBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="RegistrationStatusDot" Width="8" Height="8" Fill="#FF3B30" VerticalAlignment="Center" />
                                    <TextBlock x:Name="RegistrationStatusText" Text="Not registered" FontSize="12" FontWeight="SemiBold" Foreground="#B3261E" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Button x:Name="ReconnectButton" Content="Reconnect" Style="{StaticResource RoundedButton}" HorizontalAlignment="Left" Click="ReconnectButton_Click" />
                    </StackPanel>
                </Border>

                <!-- AI configuration - values only, never the API key itself. -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="AI CONFIGURATION" Style="{StaticResource CardTitle}" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Base URL" Style="{StaticResource RowLabel}" />
                            <TextBlock Grid.Column="1" x:Name="BaseUrlText" Style="{StaticResource RowValue}" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Model" Style="{StaticResource RowLabel}" />
                            <TextBlock Grid.Column="1" x:Name="ModelText" Style="{StaticResource RowValue}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="API key" Style="{StaticResource RowLabel}" />
                            <Border Grid.Column="1" Style="{StaticResource StatusPillBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="ApiKeyStatusDot" Width="8" Height="8" Fill="#FF3B30" VerticalAlignment="Center" />
                                    <!-- Only ever "Configured" or "Missing" - never the key value. -->
                                    <TextBlock x:Name="ApiKeyStatusText" Text="Missing" FontSize="12" FontWeight="SemiBold" Foreground="#B3261E" Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Current request -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CURRENT REQUEST" Style="{StaticResource CardTitle}" />
                        <TextBlock x:Name="CurrentRequestText" Text="Idle" FontSize="14" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Activity log -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="ACTIVITY LOG" Style="{StaticResource CardTitle}" />
                        <ScrollViewer x:Name="ActivityLogScroll" Height="220" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ActivityLogList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#4B5563" TextWrapping="Wrap" Margin="0,0,0,4" FontFamily="Consolas, Menlo, monospace" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
