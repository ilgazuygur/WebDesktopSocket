<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SocketDesktop.Avalonia.ViewModels"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="760"
        x:Class="SocketDesktop.Avalonia.MainWindow"
        Width="480" Height="760"
        MinWidth="420" MinHeight="560"
        Title="SocketDesktop · Avalonia"
        Background="#F0F2F5">

    <!-- The chat UI lives entirely on the web (SocketWeb). This window is an
         operational dashboard for the cross-platform desktop AI bridge:
         connection + registration state, AI configuration status (never the
         key value), the current AI request, and a live activity log. -->

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="TextBlock.cardTitle">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style Selector="TextBlock.rowLabel">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.rowValue">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Styles>

    <ScrollViewer>
        <StackPanel Margin="16">

            <!-- Header -->
            <StackPanel Margin="4,0,4,14">
                <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="Bold" Foreground="#111827" />
                <TextBlock Text="{Binding Platform}" FontSize="13" Foreground="#6B7280" Margin="0,2,0,0" />
                <TextBlock Text="AI bridge between SocketWeb and the AI provider" FontSize="12" Foreground="#9CA3AF" Margin="0,2,0,0" />
            </StackPanel>

            <!-- Connection -->
            <Border Classes="card">
                <StackPanel>
                    <TextBlock Classes="cardTitle" Text="CONNECTION" />

                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Classes="rowLabel" Text="Server URL" />
                        <TextBlock Grid.Column="1" Classes="rowValue" TextAlignment="Right" Text="{Binding ServerUrl}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Classes="rowLabel" Text="WebSocket" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Ellipse Width="9" Height="9" Fill="{Binding ConnectionStatusBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ConnectionStatusText}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#111827" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                        <TextBlock Grid.Column="0" Classes="rowLabel" Text="Registration" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Ellipse Width="9" Height="9" Fill="{Binding RegistrationBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RegistrationText}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#111827" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Classes="action" Name="ConnectButton" Content="Connect"
                                Command="{Binding ConnectCommand}"
                                Background="#2563EB" Foreground="White" />
                        <Button Classes="action" Name="DisconnectButton" Content="Disconnect"
                                Command="{Binding DisconnectCommand}" />
                        <Button Classes="action" Name="ReconnectButton" Content="Reconnect"
                                Command="{Binding ReconnectCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AI configuration (never the key value) -->
            <Border Classes="card">
                <StackPanel>
                    <TextBlock Classes="cardTitle" Text="AI CONFIGURATION" />

                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Classes="rowLabel" Text="Base URL" />
                        <TextBlock Grid.Column="1" Classes="rowValue" TextAlignment="Right" Text="{Binding BaseUrl}" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Classes="rowLabel" Text="Model" />
                        <TextBlock Grid.Column="1" Classes="rowValue" TextAlignment="Right" Text="{Binding Model}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Classes="rowLabel" Text="API key" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Ellipse Width="9" Height="9" Fill="{Binding ApiKeyStatusBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ApiKeyStatusText}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#111827" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Classes="rowLabel" Text="Status" />
                        <TextBlock Grid.Column="1" Classes="rowValue" TextAlignment="Right"
                                   Foreground="{Binding AiConfigBrush}" Text="{Binding AiConfigSummary}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Current request -->
            <Border Classes="card">
                <StackPanel>
                    <TextBlock Classes="cardTitle" Text="CURRENT REQUEST" />
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                 Fill="#F59E0B" IsVisible="{Binding IsProcessingRequest}" />
                        <TextBlock Text="{Binding CurrentRequestText}" FontSize="14"
                                   Foreground="#111827" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Activity log -->
            <Border Classes="card">
                <StackPanel>
                    <TextBlock Classes="cardTitle" Text="ACTIVITY LOG" />
                    <ScrollViewer Height="220" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ActivityLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="#4B5563"
                                               TextWrapping="Wrap" Margin="0,0,0,4"
                                               FontFamily="Menlo,Consolas,monospace" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
