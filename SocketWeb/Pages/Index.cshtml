@page
@model SocketWeb.Pages.IndexModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SocketWeb - AI Chat</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="app">
        <!-- Mobile-only: click this (behind the open sidebar) to close it. -->
        <div id="sidebarBackdrop" class="sidebar-backdrop"></div>

        <aside id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <button id="newChatBtn" class="new-chat-btn" type="button">
                    <span class="icon" aria-hidden="true">+</span> New chat
                </button>
            </div>

            <!-- Session rows are rendered here by chat.js. -->
            <nav id="sessionList" class="session-list" aria-label="Chat sessions"></nav>
        </aside>

        <main class="main">
            <header class="main-header">
                <button id="sidebarToggle" class="icon-btn sidebar-toggle" type="button" aria-label="Toggle sidebar">
                    &#9776;
                </button>

                <h1 id="sessionTitleHeading" class="session-title">New chat</h1>

                <div class="status-group">
                    <div id="wsStatusPill" class="status-pill disconnected">
                        <span class="dot" aria-hidden="true"></span>
                        <span id="wsStatusLabel" class="label">Connecting…</span>
                    </div>
                    <div id="desktopStatusPill" class="status-pill offline">
                        <span class="dot" aria-hidden="true"></span>
                        <span id="desktopStatusLabel" class="label">AI: Offline</span>
                    </div>
                </div>
            </header>

            <div id="chatArea" class="chat-area">
                <div id="emptyState" class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                    </svg>
                    <h2>Start a new conversation</h2>
                    <p>Type a message below to begin, or pick a previous chat from the sidebar.</p>
                </div>

                <div id="messageList" class="message-list" hidden></div>
            </div>

            <footer class="composer">
                <div id="requestError" class="request-error" role="alert" hidden></div>

                <div class="composer-row">
                    <textarea
                        id="messageInput"
                        class="composer-input"
                        placeholder="Message the AI…"
                        rows="1"
                        aria-label="Message"></textarea>
                    <button id="sendBtn" class="send-btn" type="button" disabled>Send</button>
                </div>

                <div id="thinkingIndicator" class="thinking-indicator" hidden>
                    <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                    AI is thinking…
                </div>
            </footer>
        </main>
    </div>

    <script src="~/js/api.js"></script>
    <script src="~/js/ws.js"></script>
    <script src="~/js/chat.js"></script>
</body>
</html>
