@page
@model SocketWeb.Pages.IndexModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SocketWeb - WebSocket Chat Demo</title>
    <style>
        :root {
            --bg: #f0f2f5;
            --header-bg: #ffffff;
            --bubble-mine: #007aff;
            --bubble-theirs: #e5e5ea;
            --text-theirs: #1c1c1e;
            --online: #34c759;
            --offline: #ff3b30;
        }

        * { box-sizing: border-box; }

        html, body {
            height: 100%;
            margin: 0;
            font-family: -apple-system, Segoe UI, Arial, sans-serif;
            background: var(--bg);
        }

        /* The whole app is a vertical flex column that fills the screen:
           header on top, scrollable chat log in the middle, composer
           (input + send button) pinned to the bottom. */
        .app {
            display: flex;
            flex-direction: column;
            height: 100%;
            max-width: 480px;
            margin: 0 auto;
            background: var(--bg);
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.08);
        }

        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 18px;
            background: var(--header-bg);
            border-bottom: 1px solid #e0e0e0;
        }

        .header h1 {
            font-size: 18px;
            margin: 0;
        }

        /* The little pill in the top-right showing Connected/Disconnected. */
        .status-pill {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 999px;
            background: #f0f0f0;
        }

        .status-pill .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--offline);
        }

        .status-pill.connected .dot { background: var(--online); }
        .status-pill.connected { color: #1a7f37; }
        .status-pill.disconnected { color: #b3261e; }

        .chat-log {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* One chat bubble. ".mine" (messages sent as "Web") is aligned
           right and colored blue; anything else (e.g. "Desktop") is
           aligned left and colored light gray, like a typical chat app. */
        .bubble-row {
            display: flex;
            flex-direction: column;
            max-width: 75%;
        }

        .bubble-row.mine { align-self: flex-end; align-items: flex-end; }
        .bubble-row.theirs { align-self: flex-start; align-items: flex-start; }

        .sender-label {
            font-size: 11px;
            color: #8e8e93;
            margin: 0 4px 2px;
        }

        .bubble {
            padding: 8px 12px;
            border-radius: 16px;
            line-height: 1.35;
            word-wrap: break-word;
        }

        .bubble-row.mine .bubble {
            background: var(--bubble-mine);
            color: white;
            border-bottom-right-radius: 4px;
        }

        .bubble-row.theirs .bubble {
            background: var(--bubble-theirs);
            color: var(--text-theirs);
            border-bottom-left-radius: 4px;
        }

        .bubble-time {
            font-size: 10px;
            color: #8e8e93;
            margin: 2px 4px 0;
        }

        .composer {
            display: flex;
            gap: 8px;
            padding: 12px;
            background: var(--header-bg);
            border-top: 1px solid #e0e0e0;
        }

        #messageInput {
            flex: 1;
            padding: 10px 14px;
            border: 1px solid #d0d0d0;
            border-radius: 20px;
            font-size: 14px;
            outline: none;
        }

        #messageInput:focus { border-color: var(--bubble-mine); }

        #sendBtn {
            padding: 0 20px;
            border: none;
            border-radius: 20px;
            background: var(--bubble-mine);
            color: white;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
        }

        #sendBtn:hover { background: #0064d1; }
        #sendBtn:disabled { background: #b0d4fb; cursor: not-allowed; }
    </style>
</head>
<body>
    <div class="app">
        <div class="header">
            <h1>SocketWeb</h1>

            <!-- Shows whether we are currently connected to the WebSocket server. -->
            <div id="status" class="status-pill disconnected">
                <span class="dot"></span>
                <span id="statusText">Disconnected</span>
            </div>
        </div>

        <!-- Every message received from the server (from web or desktop) shows up here as a chat bubble. -->
        <div id="log" class="chat-log"></div>

        <!-- Message input + send button. -->
        <div class="composer">
            <input type="text" id="messageInput" placeholder="Type a message..." autocomplete="off" />
            <button id="sendBtn">Send</button>
        </div>
    </div>

    <script src="~/js/socket-client.js"></script>
</body>
</html>
